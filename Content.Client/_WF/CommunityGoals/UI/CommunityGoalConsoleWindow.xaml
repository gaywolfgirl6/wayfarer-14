<controls:FancyWindow
        xmlns="https://spacestation14.io"
        xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
        xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
        Title="Community Goals Terminal" MinSize="700 480" SetSize="820 540">
    <BoxContainer Orientation="Horizontal" VerticalExpand="True" SeparationOverride="0">

        <!-- ═══ Left column: Goals ═══ -->
        <BoxContainer Orientation="Vertical" VerticalExpand="True"
                      SetWidth="480" SeparationOverride="4" Margin="0 0 4 0">
            <Label Text="Community Goals" FontColorOverride="#aaffaa"
                   HorizontalAlignment="Center" Margin="6 6 6 2"/>
            <PanelContainer VerticalExpand="True">
                <PanelContainer.PanelOverride>
                    <gfx:StyleBoxFlat BackgroundColor="#1B1B1E"/>
                </PanelContainer.PanelOverride>
                <ScrollContainer VerticalExpand="True" HScrollEnabled="False">
                    <BoxContainer Name="GoalsList" Orientation="Vertical"
                                  HorizontalExpand="True" Margin="6 4"/>
                </ScrollContainer>
            </PanelContainer>
        </BoxContainer>

        <!-- Divider -->
        <PanelContainer MinWidth="2">
            <PanelContainer.PanelOverride>
                <gfx:StyleBoxFlat BackgroundColor="#444444"/>
            </PanelContainer.PanelOverride>
        </PanelContainer>

        <!-- ═══ Right column: Staging ═══ -->
        <BoxContainer Orientation="Vertical" VerticalExpand="True" HorizontalExpand="True"
                      SizeFlagsStretchRatio="2" SeparationOverride="4" Margin="4 0 0 0">
            <Label Text="Staging Area" FontColorOverride="#ddddaa"
                   HorizontalAlignment="Center" Margin="6 6 6 2"/>
            <PanelContainer VerticalExpand="True">
                <PanelContainer.PanelOverride>
                    <gfx:StyleBoxFlat BackgroundColor="#1B1B1E"/>
                </PanelContainer.PanelOverride>
                <BoxContainer Orientation="Vertical" VerticalExpand="True">
                    <RichTextLabel Name="HintLabel"
                           HorizontalExpand="True" HorizontalAlignment="Center"
                           Margin="6 10 6 4"/>
                    <ScrollContainer VerticalExpand="True" HScrollEnabled="False">
                        <BoxContainer Name="StagingList" Orientation="Vertical"
                                      HorizontalExpand="True" Margin="4 2"/>
                    </ScrollContainer>
                </BoxContainer>
            </PanelContainer>
            <Label Name="StagingCount" Text="Nothing staged" FontColorOverride="#888888"
                   HorizontalAlignment="Center" Margin="4 4 4 2"/>
            <Button Name="CommitButton" Text="Contribute All"
                    HorizontalExpand="True" Disabled="True" Margin="6 0"/>
            <Button Name="ClearButton" Text="Return Items"
                    HorizontalExpand="True" Disabled="True" Margin="6 4"/>
        </BoxContainer>

    </BoxContainer>
</controls:FancyWindow>
